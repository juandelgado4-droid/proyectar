{
  "name": "aurora-letras",
  "version": "1.5.0",
  "description": "Proyector de letras sincronizadas con visuales",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/juandelgado4-droid/proyectar.git"
  },
  "homepage": "https://github.com/juandelgado4-droid/proyectar",
  "bugs": {
    "url": "https://github.com/juandelgado4-droid/proyectar/issues"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win"
  },
  "author": "juandelgado4-droid",
  "license": "MIT",
  "devDependencies": {
    "electron": "36.3.1",
    "electron-builder": "^26.15.3",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.auroraletras.player",
    "productName": "Aurora Letras",
    "win": {
      "target": "nsis",
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "get-media.ps1",
        "to": "get-media.ps1"
      }
    ],
    "files": [
      "**/*",
      "!dist/**",
      "!scraper.js",
      "!scraper_history.json",
      "!scraper_log.txt",
      "!debug_*.png",
      "!scraper_session",
      "!get-media.ps1"
    ]
  }
}
