{
  "name": "proyector-cafecito",
  "version": "1.1.7",
  "description": "Proyector de letras para Cafecito o Miedo",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win"
  },
  "author": "Cafecito o Miedo",
  "license": "MIT",
  "devDependencies": {
    "electron": "36.3.1",
    "electron-builder": "^26.15.3",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.cafecitoomiedo.proyector",
    "productName": "Proyector Cafecito",
    "win": {
      "target": "nsis",
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "get-media.ps1",
        "to": "get-media.ps1"
      }
    ],
    "files": [
      "**/*",
      "!dist/**",
      "!scraper.js",
      "!scraper_history.json",
      "!scraper_log.txt",
      "!debug_*.png",
      "!scraper_session",
      "!get-media.ps1"
    ]
  }
}
